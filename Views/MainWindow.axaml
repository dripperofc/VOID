<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Void.ViewModels"
        x:Class="Void.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Void" Width="1100" Height="700" Background="#313338">

    <Grid>
        <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="72, 240, *">
            <Border Grid.Column="0" Background="#1E1F22" Padding="0,12,0,0">
                <Button Command="{Binding GoToDmsCommand}" Width="48" Height="48" CornerRadius="16" Background="#5865F2" HorizontalAlignment="Center">
                    <TextBlock Text="V" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Border>

            <DockPanel Grid.Column="1" Background="#2B2D31">
                <Border DockPanel.Dock="Bottom" Background="#232428" Padding="8" Height="52">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#5865F2">
                            <TextBlock Text="{Binding CurrentUser.Nickname[0]}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding CurrentUser.Nickname}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentUser.Username, StringFormat='@{0}'}" Foreground="#B5BAC1" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBlock Text="MENSAGENS DIRETAS" Foreground="#949BA4" FontSize="11" FontWeight="Bold" Margin="16,16,0,0"/>
            </DockPanel>

            <DockPanel Grid.Column="2" Background="#313338">
                <Border DockPanel.Dock="Bottom" Padding="16">
                    <TextBox Text="{Binding Input}" Watermark="Conversar..." Background="#383A40" Foreground="White" CornerRadius="8" BorderThickness="0">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding ProcessMessageCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                </Border>

                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                                    <Border Grid.Column="0" Width="40" Height="40" Background="#383A40" CornerRadius="20" Margin="0,0,12,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Author[0]}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Author}" Foreground="{Binding NameColor}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Badge}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Timestamp}" Foreground="#949BA4" FontSize="11" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}" Foreground="#DBDEE1" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <Border IsVisible="{Binding !IsLoggedIn}" Background="#1E1F22">
            <Border Background="#313338" Padding="32" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <StackPanel Spacing="15">
                    <TextBlock Text="Void" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding UsernameInput}" Watermark="Usuário (@)"/>
                    <StackPanel IsVisible="{Binding IsRegisterView}">
                        <TextBox Text="{Binding NicknameInput}" Watermark="Apelido" Margin="0,10,0,0"/>
                    </StackPanel>
                    <TextBox Text="{Binding PasswordInput}" Watermark="Senha" PasswordChar="*"/>
                    
                    <Button IsVisible="{Binding !IsRegisterView}" Command="{Binding ConfirmLoginCommand}" Content="ENTRAR" Background="#5865F2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="45"/>
                    <Button IsVisible="{Binding IsRegisterView}" Command="{Binding ConfirmRegisterCommand}" Content="CRIAR CONTA" Background="#23A559" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="45"/>
                    
                    <Button Command="{Binding ToggleViewCommand}" Background="Transparent" HorizontalAlignment="Center">
                        <TextBlock Text="Mudar para Login/Registro" Foreground="#00A8FC" TextDecorations="Underline"/>
                    </Button>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>