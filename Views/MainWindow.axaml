<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Void.ViewModels"
        x:Class="Void.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Void Client"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1F22">

    <Grid ColumnDefinitions="72,240,*,200">
        
        <!-- BARRA DE SERVIDORES -->
        <ScrollViewer Grid.Column="0" Background="#0F0F12">
            <StackPanel Margin="12,12,12,0" Spacing="8">
                <ItemsControl ItemsSource="{Binding Servers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="48" Height="48"
                                    CornerRadius="24"
                                    Background="#2B2D31"
                                    Foreground="#B5BAC1"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Margin="0,0,0,8"
                                    Command="{Binding $parent[Window].DataContext.SelectServerCommand}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Name[0]}" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <Button Command="{Binding CreateServerCommand}"
                        Width="48" Height="48"
                        CornerRadius="24"
                        Background="#2B2D31"
                        Foreground="#23A55A"
                        FontSize="24"
                        Margin="0,8,0,0">
                    <TextBlock Text="+" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </ScrollViewer>
        
        <!-- BARRA DE CANAIS -->
        <Grid Grid.Column="1" Background="#1E1F22" RowDefinitions="Auto,*,Auto">
            
            <Border Grid.Row="0" Padding="16,12" BorderBrush="#2B2D31" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding CurrentServer.Name}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="White"/>
            </Border>
            
            <ScrollViewer Grid.Row="1">
                <StackPanel Margin="8">
                    
                    <TextBlock Text="CANAIS DE TEXTO" 
                               FontSize="11" 
                               Foreground="#949BA4" 
                               Margin="8,16,8,4"/>
                    
                    <ItemsControl ItemsSource="{Binding TextChannels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,6"
                                        Background="Transparent"
                                        Foreground="#949BA4"
                                        CornerRadius="4"
                                        Command="{Binding $parent[Window].DataContext.SelectChannelCommand}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="#" Width="20"/>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <TextBlock Text="CANAIS DE VOZ" 
                               FontSize="11" 
                               Foreground="#949BA4" 
                               Margin="8,20,8,4"/>
                    
                    <ItemsControl ItemsSource="{Binding VoiceChannels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,6"
                                        Background="Transparent"
                                        Foreground="#23A55A"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🔊" Width="20"/>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <TextBlock Text="MENSAGENS DIRETAS" 
                               FontSize="11" 
                               Foreground="#949BA4" 
                               Margin="8,20,8,4"/>
                    
                    <ItemsControl ItemsSource="{Binding Friends}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,6"
                                        Background="Transparent"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{Binding AvatarColor}">
                                            <TextBlock Text="{Binding Initials}" 
                                                       Foreground="White" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       FontSize="12"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                                            <TextBlock Text="{Binding Status}" 
                                                       Foreground="#23A55A" 
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                </StackPanel>
            </ScrollViewer>
            
            <Border Grid.Row="2" Background="#111214" Padding="8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="{Binding CurrentUser.AvatarColor}">
                        <TextBlock Text="{Binding CurrentUser.Initials}" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="{Binding CurrentUser.Nickname}" 
                                   Foreground="White" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="🟢 Online" 
                                   Foreground="#B5BAC1" 
                                   FontSize="11"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <Button Command="{Binding ToggleMicrophoneCommand}" 
                                Width="28" Height="28" 
                                Background="Transparent" 
                                Foreground="#B5BAC1">
                            <TextBlock Text="🎤"/>
                        </Button>
                        <Button Command="{Binding OpenSettingsCommand}" 
                                Width="28" Height="28" 
                                Background="Transparent" 
                                Foreground="#B5BAC1">
                            <TextBlock Text="⚙️"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
        </Grid>
        
        <!-- ÁREA DE CHAT -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
            
            <Border Grid.Row="0" Padding="16,12" BorderBrush="#2B2D31" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="#" Foreground="#949BA4" FontSize="18"/>
                    <TextBlock Text="{Binding CurrentChannel.Name}" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentChannel.Topic}" 
                               Foreground="#949BA4" 
                               FontSize="13" 
                               Margin="8,0,0,0"/>
                </StackPanel>
            </Border>
            
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Messages}" Margin="16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,16">
                                <Border Grid.Column="0" 
                                        Width="40" Height="40" 
                                        CornerRadius="20" 
                                        Background="{Binding Author.AvatarColor}"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Author.Initials}" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Author.Nickname}" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding TimeDisplay}" 
                                                   Foreground="#949BA4" 
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" 
                                               Foreground="#DCDDDE" 
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <Border Grid.Row="2" Padding="16" Background="#1E1F22">
                <Border Background="#383A40" CornerRadius="8" Padding="12,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0" 
                                Content="+" 
                                Background="Transparent" 
                                Foreground="#B5BAC1"
                                Width="24" Height="24"/>
                        
                        <TextBox Grid.Column="1" 
                                 Text="{Binding MessageInput}" 
                                 Watermark="Enviar mensagem"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Margin="8,0"/>
                        
                        <Button Grid.Column="2" 
                                Content="😊" 
                                Background="Transparent" 
                                Foreground="#B5BAC1"
                                Width="24" Height="24"
                                Command="{Binding SendMessageCommand}"/>
                    </Grid>
                </Border>
            </Border>
            
        </Grid>
        
        <!-- BARRA DE MEMBROS -->
        <Border Grid.Column="3" Background="#1E1F22" Padding="16,16,8,16">
            <StackPanel>
                <TextBlock Text="{Binding OnlineMembersHeader}" 
                           FontSize="11" 
                           Foreground="#949BA4" 
                           Margin="0,0,0,8"/>
                
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <Border Width="32" Height="32" CornerRadius="16" Background="{Binding CurrentUser.AvatarColor}">
                        <TextBlock Text="{Binding CurrentUser.Initials}" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUser.Nickname}" 
                               Foreground="#23A55A" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text="{Binding OfflineMembersHeader}" 
                           FontSize="11" 
                           Foreground="#949BA4" 
                           Margin="0,24,0,8"/>
            </StackPanel>
        </Border>
        
    </Grid>
</Window>