<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Void.ViewModels"
        x:Class="Void.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:Name="Root"
        Title="{Binding WindowTitle}"
        Width="1200" MinWidth="850"
        Height="750" MinHeight="500"
        Background="{StaticResource BgPrimary}"
        WindowStartupLocation="CenterScreen">

    <Panel>
        <Border IsVisible="{Binding !IsLoggedIn}" Background="{StaticResource BgSecondary}" CornerRadius="20" Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
            <StackPanel Spacing="24">
                <TextBlock Text="VOID" FontSize="36" FontWeight="Black" Foreground="{StaticResource VoidNeon}" HorizontalAlignment="Center"/>
                
                <Border Background="{StaticResource BgTertiary}40" CornerRadius="16" Padding="28">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Entrar" IsVisible="{Binding !IsRegisterView}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Criar Conta" IsVisible="{Binding IsRegisterView}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>

                        <TextBox Text="{Binding NicknameInput}" Watermark="Apelido (Nickname)" IsVisible="{Binding IsRegisterView}"/>
                        
                        <TextBox Text="{Binding UsernameInput}" Watermark="Usuário"/>
                        <TextBox Text="{Binding PasswordInput}" PasswordChar="●" Watermark="Senha"/>

                        <Button Command="{Binding ConfirmLoginCommand}" 
                                IsVisible="{Binding !IsRegisterView}" 
                                Classes="ActionButton" 
                                Background="{StaticResource VoidNeon}" 
                                Content="Entrar" 
                                HorizontalAlignment="Stretch"/>

                        <Button Command="{Binding ConfirmRegisterCommand}" 
                                IsVisible="{Binding IsRegisterView}" 
                                Classes="ActionButton" 
                                Background="{StaticResource VoidNeon}" 
                                Content="Registrar" 
                                HorizontalAlignment="Stretch"/>
                        
                        <Button Command="{Binding ToggleViewCommand}" Background="Transparent" HorizontalAlignment="Center">
                            <Panel>
                                <TextBlock Text="Não tem conta? Registre-se" IsVisible="{Binding !IsRegisterView}" FontSize="12" Foreground="{StaticResource VoidNeon}"/>
                                <TextBlock Text="Já tem conta? Entre aqui" IsVisible="{Binding IsRegisterView}" FontSize="12" Foreground="{StaticResource VoidNeon}"/>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="80, 260, *">

            <Border Grid.Column="0" Background="{StaticResource BgSecondary}" Padding="10">
                <StackPanel Spacing="12">
                    <Button Classes="ServerIcon" Content="💬" Command="{Binding GoToDmsCommand}"/>
                    <Border Height="2" Background="{StaticResource BorderPrimary}" Margin="10,0"/>
                    
                    <ItemsControl ItemsSource="{Binding Servers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="ServerIcon" Content="{Binding Name[0]}" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectServerCommand}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource BorderPrimary}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom" Background="{StaticResource BgQuaternary}" Padding="10">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource VoidPurple}">
                                <TextBlock Text="{Binding CurrentUser.Nickname[0], FallbackValue='V'}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.Nickname}" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding CurrentUser.Username, StringFormat='@{0}'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <Button Background="Transparent" Foreground="{Binding MuteColor}" Content="{Binding MuteIcon}" Command="{Binding ToggleMuteCommand}" Padding="6" CornerRadius="4"/>
                                <Button Background="Transparent" Foreground="{Binding DeafenColor}" Content="{Binding DeafenIcon}" Command="{Binding ToggleDeafenCommand}" Padding="6" CornerRadius="4"/>
                                <Button Background="Transparent" Foreground="{StaticResource TextMuted}" Content="⚙️" Command="{Binding OpenSettingsCommand}" Padding="6" CornerRadius="4"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer>
                        <StackPanel>
                            <StackPanel IsVisible="{Binding IsInServer}">
                                <TextBlock Text="CANAIS DE TEXTO" Margin="16,16,16,8" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                <ItemsControl ItemsSource="{Binding CurrentChannels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Classes="ChannelItem" Content="{Binding Name, StringFormat='# {0}'}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Foreground="{StaticResource TextSecondary}"
                                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectChannelCommand}" CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding !IsInServer}">
                                <TextBox Text="{Binding FriendNameInput}" Watermark="Adicionar amigo..." Margin="10,10,10,15">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter" Command="{Binding AddFriendCommand}"/>
                                    </TextBox.KeyBindings>
                                </TextBox>
                                <TextBlock Text="MENSAGENS DIRETAS" Margin="16,0,16,8" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}"/>
                                <ItemsControl ItemsSource="{Binding Friends}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Classes="ChannelItem" Content="{Binding Name, StringFormat='@ {0}'}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Foreground="{StaticResource TextSecondary}"
                                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectFriendCommand}" CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto" Background="{StaticResource BgPrimary}">
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderPrimary}" BorderThickness="0,0,0,1" Padding="16">
                    <TextBlock Text="{Binding CurrentChatName, StringFormat='# {0}'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Author.Nickname}" FontWeight="Bold" Foreground="#00D4AA"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" Padding="16">
                    <TextBox Text="{Binding Input}" Watermark="Digite sua mensagem...">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding ProcessMessageCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                </Border>
            </Grid>
        </Grid>
        
        <Border IsVisible="{Binding ShowWelcomePopup}" Background="{StaticResource VoidPurple}" Padding="20,10" CornerRadius="8" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="{Binding WelcomeMessage}" Foreground="White" FontWeight="Bold"/>
        </Border>
    </Panel>
</Window>