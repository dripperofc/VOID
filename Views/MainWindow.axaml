<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Void.ViewModels"
        x:Class="Void.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Void" Width="1100" Height="700" Background="#313338">

    <Grid>
        <Grid ColumnDefinitions="72, 240, *">
            <Border Grid.Column="0" Background="#1E1F22" Padding="0,12,0,0">
                <StackPanel Spacing="12">
                    <Button Command="{Binding GoToDmsCommand}" Width="48" Height="48" CornerRadius="16" Background="#5865F2" HorizontalAlignment="Center">
                        <TextBlock Text="V" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Separator Background="#35363C" Margin="20,0" Height="2"/>
                    <ItemsControl ItemsSource="{Binding Servers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectServerCommand}" CommandParameter="{Binding}" Width="48" Height="48" CornerRadius="24" Background="#313338" Margin="0,0,0,12" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Initial}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).RequestDeleteServerCommand}" CommandParameter="{Binding}" Content="×" Foreground="Red" Background="Transparent" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,5,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding ToggleCreateServerCommand}" Width="48" Height="48" CornerRadius="24" Background="#313338" BorderBrush="#23A559" BorderThickness="1" HorizontalAlignment="Center">
                        <TextBlock Text="+" Foreground="#23A559" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>

            <DockPanel Grid.Column="1" Background="#2B2D31">
                <Border DockPanel.Dock="Top" Padding="10" BorderBrush="#1E1F22" BorderThickness="0,0,0,1" Height="48">
                    <Button Content="Procurar..." Background="#1E1F22" Foreground="#949BA4" FontSize="12" HorizontalAlignment="Stretch" CornerRadius="4"/>
                </Border>
                <Border DockPanel.Dock="Bottom" Background="#232428" Padding="8" Height="52">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#5865F2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.Name[0]}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                            <TextBlock Text="{Binding CurrentUser.Name}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentUser.Status}" Foreground="#23A559" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding OpenProfileSettingsCommand}" Background="Transparent" Padding="4">
                            <TextBlock Text="⚙️" Foreground="#B5BAC1" FontSize="18"/>
                        </Button>
                    </Grid>
                </Border>
                <ScrollViewer>
                    <Border Padding="8">
                        <StackPanel>
                            <Border IsVisible="{Binding IsCreatingServer}" Background="#1E1F22" CornerRadius="8" Padding="8" Margin="0,0,0,10">
                                <StackPanel Spacing="5">
                                    <TextBox Text="{Binding NewServerName}" Watermark="Nome..."/>
                                    <Button Command="{Binding ConfirmCreateServerCommand}" Content="Criar" Background="#23A559" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel IsVisible="{Binding IsShowingFriends}">
                                <TextBlock Text="MENSAGENS DIRETAS" Foreground="#949BA4" FontSize="11" FontWeight="Bold" Margin="8,10,0,8"/>
                                <ListBox ItemsSource="{Binding Friends}" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectFriendCommand}" CommandParameter="{Binding}" Background="Transparent" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Border Width="32" Height="32" CornerRadius="16" Background="#72767D"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding IsInServer}">
                                <TextBlock Text="CANAIS DE TEXTO" Foreground="#949BA4" FontSize="11" FontWeight="Bold" Margin="8,10,0,8"/>
                                <ListBox ItemsSource="{Binding CurrentChannels}" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding}" Foreground="#949BA4"/>
                                            </Button>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </DockPanel>

            <DockPanel Grid.Column="2" Background="#313338">
                
                <Border IsVisible="{Binding !IsInServer}" DockPanel.Dock="Top" Height="48" BorderBrush="#26272D" BorderThickness="0,0,0,1" Padding="16,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="@" Foreground="#80848E" FontSize="20"/>
                            <TextBlock Text="{Binding CurrentChatName}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="5" Background="#23A559" VerticalAlignment="Center" Margin="5,0,0,0"/> </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <Button Command="{Binding StartVoiceCallCommand}" Background="Transparent" Padding="0" ToolTip.Tip="Iniciar Chamada de Voz">
                                <TextBlock Text="📞" Foreground="#B5BAC1" FontSize="18"/>
                            </Button>
                            <Button Command="{Binding StartVideoCallCommand}" Background="Transparent" Padding="0" ToolTip.Tip="Iniciar Chamada de Vídeo">
                                <TextBlock Text="📹" Foreground="#B5BAC1" FontSize="18"/>
                            </Button>
                            <TextBlock Text="📌" Foreground="#B5BAC1" FontSize="18" VerticalAlignment="Center" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border IsVisible="{Binding IsInServer}" DockPanel.Dock="Top" Height="48" BorderBrush="#26272D" BorderThickness="0,0,0,1" Padding="16,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="#" Foreground="#80848E" FontSize="22" Margin="0,-2,0,0"/>
                            <TextBlock Text="{Binding CurrentChatName}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Width="1" Height="24" Background="#3F4147" Margin="8,0"/>
                            <TextBlock Text="Bem-vindo ao canal!" Foreground="#949BA4" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <Button Command="{Binding ToggleNotificationsCommand}" Background="Transparent" Padding="0">
                                <TextBlock Text="{Binding NotificationsEnabled, ConverterParameter='🔔', Converter={x:Null}}" Foreground="{Binding NotificationsEnabled, ConverterParameter='White', Converter={x:Null}}">
                                    <Run Text="🔔" Foreground="{Binding NotificationsEnabled, ConverterParameter='White', Converter={x:Null}}"/>
                                </TextBlock>
                            </Button>
                            <TextBlock Text="📌" Foreground="#B5BAC1" FontSize="18" VerticalAlignment="Center" Cursor="Hand"/>
                            <TextBlock Text="👥" Foreground="#B5BAC1" FontSize="18" VerticalAlignment="Center" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DockPanel Margin="16,0,16,16">
                    <Border DockPanel.Dock="Bottom" Background="#383A40" CornerRadius="8" Padding="12,0">
                        <TextBox Text="{Binding Input}" Watermark="Enviar mensagem..." Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" MinHeight="44">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding ProcessMessageCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,16">
                                        <Border Grid.Column="0" Width="40" Height="40" Background="#383A40" CornerRadius="20" VerticalAlignment="Top" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Author[0]}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Author}" Foreground="{Binding NameColor}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Badge}" FontSize="12"/>
                                                <TextBlock Text="{Binding Timestamp}" Foreground="#949BA4" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}" Foreground="#DBDEE1" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </DockPanel>
        </Grid>

        <Border IsVisible="{Binding ShowDeleteWarning}" Background="#80000000">
            <Border Background="#313338" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" CornerRadius="8" Width="400">
                <StackPanel Spacing="20">
                    <TextBlock Text="Apagar Servidor" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Tem certeza que deseja apagar este servidor? Isso não pode ser desfeito." Foreground="#DBDEE1" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                        <Button Command="{Binding CancelDeleteCommand}" Content="Cancelar" Background="Transparent" Foreground="White"/>
                        <Button Command="{Binding ConfirmDeleteServerCommand}" Content="Apagar" Background="#DA373C" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border IsVisible="{Binding ShowProfileSettings}" Background="#80000000">
            <Border Background="#313338" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32" CornerRadius="8" Width="450">
                <StackPanel Spacing="16">
                    <TextBlock Text="Personalizar Perfil (Void Nitro)" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="NOME DE EXIBIÇÃO" Foreground="#949BA4" FontSize="12" FontWeight="Bold"/>
                    <TextBox Text="{Binding CurrentUser.Name}" Background="#1E1F22" Foreground="White" BorderThickness="0" CornerRadius="4" Padding="10"/>
                    <TextBlock Text="COR DO NICK (Ex: #FF0000)" Foreground="#949BA4" FontSize="12" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding CurrentUser.Color}" Background="#1E1F22" Foreground="White" BorderThickness="0" CornerRadius="4" Padding="10"/>
                    <TextBlock Text="INSÍGNIA / EMOJI" Foreground="#949BA4" FontSize="12" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Text="{Binding CurrentUser.Badge}" Background="#1E1F22" Foreground="White" BorderThickness="0" CornerRadius="4" Padding="10"/>
                    <Button Command="{Binding CloseProfileSettingsCommand}" Content="Salvar Alterações" Background="#5865F2" Foreground="White" HorizontalAlignment="Right" Margin="0,16,0,0" Padding="20,10" CornerRadius="4"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>