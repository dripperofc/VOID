<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Void.ViewModels"
        x:Class="Void.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Void" Width="1100" Height="700" Background="#313338">

    <Grid>
        <Grid IsVisible="{Binding IsLoggedIn}" ColumnDefinitions="72, 240, *">
            
            <Border Grid.Column="0" Background="#1E1F22" Padding="0,12,0,0">
                <StackPanel Spacing="12">
                    <Button Command="{Binding GoToDmsCommand}" Width="48" Height="48" CornerRadius="16" Background="#5865F2">
                        <TextBlock Text="V" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Button>
                    <Separator Background="#35363C" Margin="20,0"/>
                    <ItemsControl ItemsSource="{Binding Servers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectServerCommand}" CommandParameter="{Binding}" Width="48" Height="48" CornerRadius="24" Background="#313338" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Initial}" Foreground="White" HorizontalAlignment="Center"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Command="{Binding ToggleCreateServerCommand}" Content="+" Width="48" Height="48" CornerRadius="24" Background="Transparent" BorderBrush="#23A559" BorderThickness="1" Foreground="#23A559"/>
                </StackPanel>
            </Border>

            <DockPanel Grid.Column="1" Background="#2B2D31">
                <Border DockPanel.Dock="Bottom" Background="#232428" Padding="8" Height="52">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Ellipse Width="32" Height="32" Fill="#5865F2"/>
                        <StackPanel Grid.Column="1" Margin="8,0">
                            <TextBlock Text="{Binding CurrentUser.Nickname}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentUser.Username, StringFormat='@{0}'}" Foreground="#B5BAC1" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="2" Background="Transparent" Content="⚙️"/>
                    </Grid>
                </Border>

                <ScrollViewer>
                    <StackPanel Margin="10">
                        <StackPanel IsVisible="{Binding IsShowingFriends}">
                            <TextBlock Text="MENSAGENS DIRETAS" Foreground="#949BA4" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBox Text="{Binding FriendNameInput}" Watermark="Adicionar amigo..." Margin="0,0,0,10">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding AddFriendCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                            <ListBox ItemsSource="{Binding Friends}" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsInServer}">
                            <TextBlock Text="CANAIS DE TEXTO" Foreground="#949BA4" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding CurrentChannels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding, StringFormat='# {0}'}" Background="Transparent" HorizontalAlignment="Stretch" Foreground="#949BA4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <DockPanel Grid.Column="2" Background="#313338">
                <Border DockPanel.Dock="Top" Height="48" BorderBrush="#26272D" BorderThickness="0,0,0,1" Padding="16,0">
                    <TextBlock Text="{Binding CurrentChatName}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <Border DockPanel.Dock="Bottom" Padding="16">
                    <TextBox Text="{Binding Input}" Watermark="Conversar..." CornerRadius="8" BorderThickness="0" Background="#383A40" Foreground="White">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding ProcessMessageCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                </Border>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Author}" Foreground="{Binding NameColor}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Badge}" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" Foreground="#DBDEE1" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <Border IsVisible="{Binding IsCreatingServer}" Background="#80000000" ZIndex="100">
            <Border Background="#313338" CornerRadius="8" Padding="20" Width="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="15">
                    <TextBlock Text="Personalize seu servidor" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBox Text="{Binding NewServerName}" Watermark="Nome do Servidor"/>
                    <Grid ColumnDefinitions="*, *">
                        <Button Command="{Binding ToggleCreateServerCommand}" Content="Voltar" Background="Transparent" Foreground="White"/>
                        <Button Grid.Column="1" Command="{Binding ConfirmCreateServerCommand}" Content="Criar" Background="#5865F2" Foreground="White" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border IsVisible="{Binding !IsLoggedIn}" Background="#1E1F22">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Spacing="10">
                <TextBlock Text="Void" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBox Text="{Binding UsernameInput}" Watermark="Usuário (@)"/>
                <StackPanel IsVisible="{Binding IsRegisterView}">
                    <TextBox Text="{Binding NicknameInput}" Watermark="Apelido"/>
                </StackPanel>
                <TextBox Text="{Binding PasswordInput}" Watermark="Senha" PasswordChar="*"/>
                <Button Command="{Binding ConfirmLoginCommand}" IsVisible="{Binding !IsRegisterView}" Content="Entrar" Background="#5865F2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Command="{Binding ConfirmRegisterCommand}" IsVisible="{Binding IsRegisterView}" Content="Registrar" Background="#23A559" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button Command="{Binding ToggleViewCommand}" Content="Alternar Login/Registro" Background="Transparent" Foreground="#00A8FC" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>